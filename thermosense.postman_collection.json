    {
      "name": "4 — Actuators",
      "item": [
        {
          "name": "GET /areas/:areaId/actuators — Liste zone A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Retourne data (array)', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});",
                  "",
                  "// Capturer le premier actuator ID pour les tests suivants",
                  "const body = pm.response.json();",
                  "if (body.data && body.data.length > 0) {",
                  "  pm.collectionVariables.set('actuatorId', body.data[0].id);",
                  "  console.log('Actuator ID capturé:', body.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/areas/{{areaAId}}/actuators",
              "host": ["{{baseUrl}}"],
              "path": ["areas", "{{areaAId}}", "actuators"]
            }
          }
        },
        {
          "name": "POST /areas/:areaId/actuators — Créer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
