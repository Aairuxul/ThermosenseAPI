{
  "info": {
    "name": "ThermosenseAPI",
    "description": "Tests de l'API Thermosense. Lancer `npm run dev`, copier les IDs de la console dans les variables, puis exécuter les requêtes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "areaAId", "value": "", "description": "ID Zone A (depuis console serveur)" },
    { "key": "areaBId", "value": "", "description": "ID Zone B (depuis console serveur)" },
    { "key": "sensorActiveId", "value": "", "description": "ID d'un capteur actif" },
    { "key": "sensorInactiveId", "value": "", "description": "ID d'un capteur inactif" },
    { "key": "actuatorId", "value": "", "description": "ID d'un actionneur existant" },
    { "key": "userId", "value": "", "description": "ID d'un utilisateur existant" },
    { "key": "createdAreaId", "value": "" },
    { "key": "createdActuatorId", "value": "" },
    { "key": "createdUserId", "value": "" },
    { "key": "createdThresholdId", "value": "" }
  ],
  "item": [
    {
      "name": "0 — Bootstrap (lancer en premier)",
      "description": "Crée des ressources de test et capture les IDs dans les variables de la collection.",
      "item": [
        {
          "name": "Créer une zone de test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Zone créée (201)', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('createdAreaId', body.id);",
                  "console.log('Zone créée — id:', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"buildingId\": \"building-test-001\",\n  \"name\": \"Zone Test — Postman\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/areas", "host": ["{{baseUrl}}"], "path": ["areas"] }
          }
        },
        {
          "name": "Créer un utilisateur de test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Utilisateur créé (201)', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('createdUserId', body.id);",
                  "console.log('Utilisateur créé — id:', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@thermosense.com\",\n  \"name\": \"Test Postman\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        }
      ]
    },
    {
      "name": "1 — Areas",
      "item": [
        {
          "name": "POST /areas — Créer une zone",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Contient id, name, buildingId, sensors', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('name');",
                  "  pm.expect(body).to.have.property('buildingId');",
                  "  pm.expect(body).to.have.property('sensors');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"buildingId\": \"building-001\",\n  \"name\": \"Zone C — Salle serveurs\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/areas", "host": ["{{baseUrl}}"], "path": ["areas"] }
          }
        },
        {
          "name": "POST /areas — 400 payload invalide",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Erreur avec code et message', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('code');",
                  "  pm.expect(body).to.have.property('message');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Zone sans buildingId\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/areas", "host": ["{{baseUrl}}"], "path": ["areas"] }
          }
        }
      ]
    },
    {
      "name": "2 — Sensors",
      "item": [
        {
          "name": "GET /sensors/:id — Capteur actif",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Schema capteur valide', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('type');",
                  "  pm.expect(body).to.have.property('status');",
                  "  pm.expect(body).to.have.property('areaId');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sensors/{{sensorActiveId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sensors", "{{sensorActiveId}}"]
            }
          }
        },
        {
          "name": "GET /sensors/:id — Capteur inactif",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Status est inactive', function () {",
                  "  pm.expect(pm.response.json().status).to.eql('inactive');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sensors/{{sensorInactiveId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sensors", "{{sensorInactiveId}}"]
            }
          }
        },
        {
          "name": "GET /sensors/:id — 404 inexistant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('Erreur notFound', function () {",
                  "  pm.expect(pm.response.json().code).to.eql('notFound');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sensors/sensor-999",
              "host": ["{{baseUrl}}"],
              "path": ["sensors", "sensor-999"]
            }
          }
        },
        {
          "name": "POST /sensors/:id/measures — Nouvelle mesure",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Mesure créée avec id et sensorId', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('sensorId');",
                  "  pm.expect(body).to.have.property('value');",
                  "  pm.expect(body).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timestamp\": \"2026-03-17T10:30:00Z\",\n  \"value\": 21.3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sensors/{{sensorActiveId}}/measures",
              "host": ["{{baseUrl}}"],
              "path": ["sensors", "{{sensorActiveId}}", "measures"]
            }
          }
        }
      ]
    },
