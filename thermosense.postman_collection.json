                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body.type).to.eql('thermostat');",
                  "  pm.expect(body.state).to.eql('off');",
                  "});",
                  "",
                  "pm.collectionVariables.set('createdActuatorId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"thermostat\",\n  \"state\": \"off\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/areas/{{areaAId}}/actuators",
              "host": ["{{baseUrl}}"],
              "path": ["areas", "{{areaAId}}", "actuators"]
            }
          }
        },
        {
          "name": "GET /actuators/:id — Détail",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
