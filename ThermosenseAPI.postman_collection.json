    {
      "name": "1 — Bootstrap",
      "item": [
        {
          "name": "Initialiser IDs seed (areas/sensors)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "const areas = (body && body.data) || [];",
                  "pm.test('Au moins 2 zones disponibles', function () { pm.expect(areas.length).to.be.at.least(2); });",
                  "",
                  "let areaA = areas.find(a => typeof a.name === 'string' && a.name.includes('Zone A')) || areas[0];",
                  "let areaB = areas.find(a => typeof a.name === 'string' && a.name.includes('Zone B')) || areas.find(a => a.id !== areaA.id) || areas[1] || areaA;",
                  "",
                  "pm.collectionVariables.set('areaAId', areaA.id);",
                  "pm.collectionVariables.set('areaBId', areaB.id);",
                  "",
                  "const allSensors = areas.flatMap(a => Array.isArray(a.sensors) ? a.sensors : []);",
                  "const active = allSensors.find(s => s.status === 'active');",
                  "const inactive = allSensors.find(s => s.status === 'inactive');",
                  "",
                  "if (active) {",
                  "  pm.collectionVariables.set('sensorActiveId', active.id);",
                  "  pm.collectionVariables.set('sensorActivId', active.id);",
                  "}",
                  "if (inactive) pm.collectionVariables.set('sensorInactiveId', inactive.id);",
                  "",
                  "console.log('IDs seed initialisés:', {",
                  "  areaAId: areaA && areaA.id,",
                  "  areaBId: areaB && areaB.id,",
                  "  sensorActiveId: active && active.id,",
                  "  sensorInactiveId: inactive && inactive.id",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/areas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "areas"
              ]
            }
          },
          "response": []
        },
