      "item": [
        {
          "name": "POST /auth/login — Succès (root/root)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Retourne token et user', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('token');",
                  "  pm.expect(body).to.have.property('user');",
                  "  pm.expect(body.user).to.have.property('id');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('jwtToken', body.token);",
                  "pm.collectionVariables.set('userId', body.user.id);",
                  "console.log('JWT capturé:', body.token.substring(0, 24) + '...');",
                  "console.log('User ID capturé:', body.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
